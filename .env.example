# Local Docker Compose defaults.
POSTGRES_USER=ed
POSTGRES_PASSWORD=123123
POSTGRES_DB=ww-db
POSTGRES_PORT=5435

API_PORT=5003
PORT=5003
RUN_MIGRATIONS=true
FE_URL=http://localhost:3000

# Used inside Docker Compose. For local non-Docker runs, use localhost and POSTGRES_PORT.
DB_URL=postgresql+asyncpg://ed:123123@postgres:5432/ww-db

# Required for authenticated application endpoints.
COGNITO_JWKS_URL=
COGNITO_USER_POOL_ID=
AWS_REGION=
COGNITO_ISSUER=
COGNITO_CLIENT_ID=

# Required for import-file endpoints that use S3.
AWS_BUCKET_NAME=
